# Maintainer: Boo15mario
pkgname=niri-sounds
pkgver=r1.7afefbd
pkgrel=1
pkgdesc='Simple Niri event sound script'
arch=('any')
url='https://github.com/boo15mario/niri-sounds'
license=('MIT')
depends=('python' 'sox')
makedepends=()
_commit='7afefbd87cf69902cf5e2897fde79a777aab747f'
source=("${pkgname}-${pkgver}.tar.gz::${url}/archive/${_commit}.tar.gz")
sha256sums=('SKIP')

package() {
  cd "niri-sounds-${_commit}"
  install -Dm755 niri_sound.py "${pkgdir}/usr/bin/niri-sounds"
  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
  install -Dm644 README.md "${pkgdir}/usr/share/doc/${pkgname}/README.md"
}
