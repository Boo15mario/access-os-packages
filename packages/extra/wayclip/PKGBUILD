# Maintainer: Boo15mario
pkgname=wayclip
pkgver=0.1.1
pkgrel=1
pkgdesc='Clipboard history manager for Wayland with daemon and GTK4 client'
arch=('x86_64')
url='https://github.com/destructatron/wayclip'
license=('MIT')
depends=('gtk4' 'wl-clipboard')
makedepends=('rust' 'cargo')
source=("${pkgname}-${pkgver}.tar.gz::${url}/archive/refs/heads/main.tar.gz")
sha256sums=('SKIP')

prepare() {
  cd "${srcdir}"
  # The GitHub archive extracts to wayclip-main, rename to expected name
  mv wayclip-main "${pkgname}-${pkgver}"
  cd "${pkgname}-${pkgver}"
  # Remove 'bundled' feature from rusqlite to use system sqlite3
  sed -i 's/features = \["bundled", "blob"\]/features = ["blob"]/' Cargo.toml
  # Build deps separately to avoid makepkg linking issues
  cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')" 2>/dev/null || \
  cargo fetch --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
  cd "${pkgname}-${pkgver}"
  # Use system sqlite3 via pkg-config
  unset RUSTFLAGS
  cargo build --release --workspace
}

package() {
  cd "${pkgname}-${pkgver}"
  install -Dm755 target/release/wayclip "${pkgdir}/usr/bin/wayclip"
  install -Dm755 target/release/wayclip-daemon "${pkgdir}/usr/bin/wayclip-daemon"
  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
  install -Dm644 README.md "${pkgdir}/usr/share/doc/${pkgname}/README.md"
}
