# Maintainer: Boo15mario
pkgname=wayclip
pkgver=0.1.1
pkgrel=1
pkgdesc='Clipboard history manager for Wayland with daemon and GTK4 client'
arch=('x86_64')
url='https://github.com/destructatron/wayclip'
license=('MIT')
depends=('gtk4' 'wl-clipboard')
makedepends=('rust' 'cargo')
source=("${pkgname}-${pkgver}.tar.gz::${url}/archive/refs/heads/main.tar.gz")
sha256sums=('SKIP')

prepare() {
  cd "wayclip-main"
  export RUSTUP_TOOLCHAIN=stable
  # Force bundled sqlite
  export LIBSQLITE3_SYS_USE_PKG_CONFIG=0
  export LIBSQLITE3_SYS_STATIC=1
  cargo fetch --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
  cd "wayclip-main"
  export RUSTUP_TOOLCHAIN=stable
  export LIBSQLITE3_SYS_USE_PKG_CONFIG=0  
  export LIBSQLITE3_SYS_STATIC=1
  export RUSTFLAGS="-C linker=gcc"
  cargo build --release --workspace
}

package() {
  cd "wayclip-main"
  install -Dm755 target/release/wayclip "${pkgdir}/usr/bin/wayclip"
  install -Dm755 target/release/wayclip-daemon "${pkgdir}/usr/bin/wayclip-daemon"
  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
  install -Dm644 README.md "${pkgdir}/usr/share/doc/${pkgname}/README.md"
}
