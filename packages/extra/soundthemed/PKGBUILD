# Maintainer: Boo15mario
pkgname=soundthemed
pkgver=r1.dc26686
pkgrel=1
pkgdesc='Freedesktop sound theme daemon for Wayland desktops'
arch=('x86_64')
url='https://github.com/boo15mario/soundthemed'
license=('MIT')
depends=('pipewire' 'sound-theme-freedesktop')
makedepends=('rust' 'cargo')
_commit='dc266868ef52eb8228fb510ab7866412ce9fa3c5'
source=("${pkgname}-${pkgver}.tar.gz::${url}/archive/${_commit}.tar.gz")
sha256sums=('SKIP')

prepare() {
  cd "${pkgname}-${_commit}"
  export RUSTUP_TOOLCHAIN=stable
  cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
  cd "${pkgname}-${_commit}"
  export RUSTUP_TOOLCHAIN=stable
  cargo build --frozen --release
}

package() {
  cd "${pkgname}-${_commit}"
  install -Dm755 target/release/soundthemed "${pkgdir}/usr/bin/soundthemed"
  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
  install -Dm644 README.md "${pkgdir}/usr/share/doc/${pkgname}/README.md"
}
