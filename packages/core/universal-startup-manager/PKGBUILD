# Maintainer: Boo15mario
pkgname=universal-startup-manager
pkgver=1.2.1
pkgrel=1
pkgdesc='Universal startup manager for Linux based on GTK4'
arch=('x86_64')
url='https://github.com/boo15mario/universal-startup-manager'
license=('GPL-3.0-only')
depends=('gtk4')
makedepends=('rust' 'cargo')
_commit='ba977557f34814793b31a080ea381ae100705e7a'
source=("${pkgname}-${pkgver}.tar.gz::${url}/archive/${_commit}.tar.gz")
sha256sums=('SKIP')

prepare() {
  cd "${pkgname}-${_commit}"
  export RUSTUP_TOOLCHAIN=stable
  cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
  cd "${pkgname}-${_commit}"
  export RUSTUP_TOOLCHAIN=stable
  cargo build --frozen --release
}

package() {
  cd "${pkgname}-${_commit}"
  install -Dm755 "target/release/${pkgname}" "${pkgdir}/usr/bin/${pkgname}"
  install -Dm644 "${pkgname}.desktop" "${pkgdir}/usr/share/applications/${pkgname}.desktop"
  install -Dm644 "${pkgname}.svg" "${pkgdir}/usr/share/icons/hicolor/scalable/apps/${pkgname}.svg"
  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
