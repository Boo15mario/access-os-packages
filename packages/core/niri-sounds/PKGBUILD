# Maintainer: Boo15mario
pkgname=niri-sounds
pkgver=0.1.0
pkgrel=1
pkgdesc="A simple python script for sound events in Niri"
arch=('any')
url="https://github.com/destructatron/niri-sounds"
license=('MIT')
depends=('python' 'sox')
makedepends=('git')
_commit='7afefbd87cf69902cf5e2897fde79a777aab747f'
source=("${pkgname}-${pkgver}.tar.gz::${url}/archive/${_commit}.tar.gz")
sha256sums=('SKIP')

prepare() {
  cd "${pkgname}-${_commit}"
}

build() {
  cd "${pkgname}-${_commit}"
  # No build step - pure Python script
  true
}

package() {
  cd "${pkgname}-${_commit}"
  install -Dm755 niri_sound.py "${pkgdir}/usr/bin/niri-sound"
  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
