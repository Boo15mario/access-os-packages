# Maintainer: Boo15mario
pkgname=waygreet
pkgver=0.1.0
pkgrel=1
pkgdesc="Accessibility-first Wayland GTK greeter for greetd"
arch=('x86_64')
url="https://github.com/boo15mario/waygreet"
license=('MIT')
depends=('gtk4' 'gtk-layer-shell' 'greetd')
makedepends=('rust' 'cargo' 'pkg-config')
_commit='ba34b2f3e5f219f29026cf36bea27cd8650c7776'
source=("${pkgname}-${pkgver}.tar.gz::${url}/archive/${_commit}.tar.gz")
sha256sums=('SKIP')

prepare() {
  cd "${pkgname}-${_commit}"
}

build() {
  cd "${pkgname}-${_commit}"
  cargo build --release
}

package() {
  cd "${pkgname}-${_commit}"
  install -Dm755 "target/release/${pkgname}" "${pkgdir}/usr/bin/${pkgname}"
  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
  install -Dm644 systemd/waygreet-orca.service "${pkgdir}/usr/share/waygreet/waygreet-orca.service"
  install -Dm644 data/waygreet.toml.example "${pkgdir}/usr/share/waygreet/waygreet.toml.example"
}
