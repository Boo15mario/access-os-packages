# Maintainer: Boo15mario
pkgname=waynotify
pkgver=0.2.0
pkgrel=1
pkgdesc="Accessible notification daemon for Wayland with freedesktop.org D-Bus compliance, GTK Layer Shell popups, and AT-SPI2 screen reader support"
arch=('any')
url="https://github.com/destructatron/waynotify"
license=('MIT')
depends=('python' 'python-gobject' 'python-dasbus' 'gtk-layer-shell' 'at-spi2-core')
makedepends=('git')
_commit='213f9266594a00090a276ef9ae956eafd3f9a25f'
source=("${pkgname}-${pkgver}.tar.gz::${url}/archive/${_commit}.tar.gz")
sha256sums=('SKIP')

prepare() {
  cd "${pkgname}-${_commit}"
}

build() {
  cd "${pkgname}-${_commit}"
  # No build step - pure Python
  true
}

package() {
  cd "${pkgname}-${_commit}"
  install -Dm755 src/waynotify "${pkgdir}/usr/bin/waynotify"
  install -Dm755 src/waynotify-client "${pkgdir}/usr/bin/waynotify-client"
  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
