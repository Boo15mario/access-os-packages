# Maintainer: Boo15mario
pkgname=soundthemed
pkgver=0.1.0
pkgrel=1
pkgdesc="Freedesktop sound theme daemon for Wayland desktops — plays event sounds for USB, battery, and more"
arch=('x86_64')
url="https://github.com/destructatron/soundthemed"
license=('MIT')
depends=('pipewire' 'gtk4' 'udev')
makedepends=('rust' 'cargo' 'pkg-config')
_commit='029eee2ee86901cee099fa900fcaf0a0a69dd591'
source=("${pkgname}-${pkgver}.tar.gz::${url}/archive/${_commit}.tar.gz")
sha256sums=('SKIP')

prepare() {
  cd "${pkgname}-${_commit}"
}

build() {
  cd "${pkgname}-${_commit}"
  cargo build --release --workspace
}

package() {
  cd "${pkgname}-${_commit}"
  install -Dm755 "target/release/${pkgname}" "${pkgdir}/usr/bin/${pkgname}"
  install -Dm755 "target/release/${pkgname}-config" "${pkgdir}/usr/bin/${pkgname}-config"
  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
