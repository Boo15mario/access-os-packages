# Maintainer: Boo15mario
pkgname=wayvol
pkgver=0.1.1
pkgrel=1
pkgdesc="Accessible GTK4 PipeWire volume mixer for Wayland"
arch=('x86_64')
url="https://github.com/boo15mario/wayvol"
license=('MIT')
depends=('gtk4' 'libadwaita' 'pipewire')
makedepends=('rust' 'cargo' 'pkg-config')
_commit='69d44d0335ece10e8c24c50c27da30ba7dba184a'
source=("${pkgname}-${pkgver}.tar.gz::${url}/archive/${_commit}.tar.gz")
sha256sums=('SKIP')

prepare() {
  cd "${pkgname}-${_commit}"
}

build() {
  cd "${pkgname}-${_commit}"
  cargo build --release
}

package() {
  cd "${pkgname}-${_commit}"
  install -Dm755 "target/release/${pkgname}" "${pkgdir}/usr/bin/${pkgname}"
}
